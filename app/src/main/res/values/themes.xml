<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.InteriorDesign3D" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@color/warm_white</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <!-- Splash screen theme -->
    <style name="Theme.InteriorDesign3D.SplashScreen" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/terracotta</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_app_icon</item>
        <item name="postSplashScreenTheme">@style/Theme.InteriorDesign3D</item>
    </style>
</resources>
